<Window x:Class="ZhenhuaDiskCleaner.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:conv="clr-namespace:ZhenhuaDiskCleaner.Converters"
        xmlns:ctrl="clr-namespace:ZhenhuaDiskCleaner.Controls"
        xmlns:models="clr-namespace:ZhenhuaDiskCleaner.Models"
        Title="振华磁盘清理工具" Height="800" Width="1300"
        MinWidth="1000" MinHeight="600"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStyle="None" AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip">

    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:FileSizeConverter x:Key="FileSizeConv"/>
        <conv:ColorToBrushConverter x:Key="ColorToBrush"/>
        <conv:NullToVisibilityConverter x:Key="NullToVis"/>
        <conv:FileTypeToIconConverter x:Key="FileTypeIcon"/>
        <conv:BoolToNegateConverter x:Key="BoolNeg"/>
        <conv:FileTypeToIconConverter x:Key="FileTypeToIconConverter"/>

    </Window.Resources>

    <Border CornerRadius="10" BorderBrush="{StaticResource BorderBrush}" BorderThickness="1" ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="28"/>
            </Grid.RowDefinitions>

            <!-- Title Bar -->
            <Border Grid.Row="0" Background="{StaticResource BackgroundMediumBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="⚡" FontSize="18" Margin="0,0,8,0"/>
                        <TextBlock Text="振华磁盘清理工具" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text=" v1.0" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,2"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right"
                                VerticalAlignment="Center" Margin="0,0,4,0">
                        <Button Content="─" Width="36" Height="28" Click="Minimize_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Content="□" Width="36" Height="28" Click="Maximize_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"/>
                        <Button Content="✕" Width="36" Height="28" Click="Close_Click" Cursor="Hand"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Toolbar + Scan Progress -->
            <Border Grid.Row="1" Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1" Padding="12,10">
                <StackPanel>


                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <!-- 0: 驱动器标签 -->
                            <ColumnDefinition Width="170"/>
                            <!-- 1: 驱动器下拉 -->
                            <ColumnDefinition Width="10"/>
                            <!-- 2: 间距 -->
                            <ColumnDefinition Width="*"/>
                            <!-- 3: 自定义路径 -->
                            <ColumnDefinition Width="10"/>
                            <!-- 4: 间距 -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- 5: 浏览按钮 -->
                            <ColumnDefinition Width="8"/>
                            <!-- 6: 间距 -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- 7: 扫描按钮组/停止 -->
                            <ColumnDefinition Width="8"/>
                            <!-- 8: 间距 -->
                            <ColumnDefinition Width="Auto"/>
                            <!-- 9: 刷新按钮 -->
                        </Grid.ColumnDefinitions>

                        <!-- 驱动器标签 -->
                        <TextBlock Grid.Column="0" Text="驱动器:" VerticalAlignment="Center"
               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,8,0" FontSize="13"/>

                        <!-- 驱动器下拉 -->
                        <ComboBox Grid.Column="1" ItemsSource="{Binding Drives}"
              SelectedItem="{Binding SelectedDrive}" DisplayMemberPath="DisplayName"
              Height="32" IsEnabled="{Binding CanScan}"/>

                        <!-- 自定义路径 -->
                        <TextBox Grid.Column="3" Text="{Binding CustomPath, UpdateSourceTrigger=PropertyChanged}"
             Height="32" VerticalContentAlignment="Center"
             IsEnabled="{Binding CanScan}"
             ToolTip="输入自定义路径（留空则使用上方选中驱动器）"/>

                        <!-- 浏览按钮 -->
                        <Button Grid.Column="5" Content="📂 浏览" Height="32" Padding="12,0"
            Style="{StaticResource SecondaryButtonStyle}"
            IsEnabled="{Binding CanScan}"
            Command="{Binding BrowseDirectoryCommand}"/>

                        <!-- 扫描按钮组（非扫描时显示） -->
                        <StackPanel Grid.Column="7" Orientation="Horizontal" VerticalAlignment="Center"
                Visibility="{Binding IsScanning, Converter={StaticResource InvBoolToVis}}">
                            <Button Height="32" Padding="14,0"
                Style="{StaticResource PrimaryButtonStyle}"
                Command="{Binding StartScanCommand}"
                IsEnabled="{Binding CanScan}">
                                <TextBlock Text="🔍 开始扫描"/>
                            </Button>
                            <Button Content="⚡ 快速扫描"
                Command="{Binding QuickScanCommand}"
                IsEnabled="{Binding CanScan}"
                ToolTip="使用 NTFS MFT 快速扫描（需管理员权限，仅支持 NTFS 分区）"
                Style="{StaticResource PrimaryButtonStyle}"
                Margin="4,0,0,0" Padding="12,0" Height="32"/>
                        </StackPanel>

                        <!-- 停止按钮（扫描时显示） -->
                        <Button Grid.Column="7" Height="32" Padding="14,0"
            Style="{StaticResource DangerButtonStyle}"
            Command="{Binding CancelScanCommand}"
            Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="⏹ 停止"/>
                        </Button>

                        <!-- 刷新按钮 -->
                        <Button Grid.Column="8" Height="32" ToolTip="刷新驱动器"
            Style="{StaticResource SecondaryButtonStyle}"
            Command="{Binding RefreshDrivesCommand}" Grid.ColumnSpan="2" Margin="4,0,0,0">
                            <TextBlock Text="🔄"/>
                        </Button>
                    </Grid>

                    <!-- Progress Row -->
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                        <Grid Margin="0,0,0,5">
                            <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"
                                       TextTrimming="CharacterEllipsis">
                                <Run Text="{Binding ScanProgress.CurrentPath, Mode=OneWay}"/>
                            </TextBlock>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <TextBlock FontSize="11" Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="{Binding ScanProgress.ScannedFiles, Mode=OneWay, StringFormat={}{0:N0}}"/>
                                    <Run Text=" 文件 · "/>
                                    <Run Text="{Binding ScanProgress.ScannedSizeText, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding ScanProgress.ElapsedText, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                        <ProgressBar Style="{StaticResource ScanProgressBarStyle}" Maximum="100"
                                     Value="{Binding ScanProgress.Percentage, Mode=OneWay}"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- Main Content Area -->
            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="260" MinWidth="160"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="*" MinWidth="400"/>
                    <ColumnDefinition Width="4"/>
                    <ColumnDefinition Width="280" MinWidth="220"/>
                </Grid.ColumnDefinitions>

                <!-- Left Panel: Directory Tree -->
                <Border Grid.Column="0" Background="{StaticResource BackgroundMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="36"/>
                            <RowDefinition Height="*"/>
                        </Grid.RowDefinitions>
                        <Border Background="{StaticResource BackgroundLightBrush}" Padding="12,0">
                            <TextBlock Text="📁 目录树" VerticalAlignment="Center"
                                       FontSize="13" FontWeight="SemiBold"/>
                        </Border>
                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                      HorizontalScrollBarVisibility="Auto">
                            <TreeView x:Name="DirectoryTree"
          VirtualizingStackPanel.IsVirtualizing="False"
          ItemsSource="{Binding RootNode.Children}"
          SelectedItemChanged="DirectoryTree_SelectedItemChanged">
                                <TreeView.ItemContainerStyle>
                                    <Style TargetType="TreeViewItem">
                                        <Setter Property="IsExpanded"
                    Value="{Binding IsExpanded, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="IsSelected"
                    Value="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"/>
                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                        <Setter Property="Background" Value="Transparent"/>
                                        <Setter Property="Padding" Value="2,3"/>
                                    </Style>
                                </TreeView.ItemContainerStyle>
                                <TreeView.ItemTemplate>
                                    <HierarchicalDataTemplate DataType="{x:Type models:FileNode}"
                                  ItemsSource="{Binding Children}">
                                        <StackPanel Orientation="Horizontal" Margin="0,1">
                                            <TextBlock Text="{Binding Converter={StaticResource FileTypeIcon}}"
                           Margin="0,0,4,0" FontSize="12"/>
                                            <TextBlock Text="{Binding Name}" FontSize="12" VerticalAlignment="Center"/>
                                            <TextBlock Text="{Binding SizeText}" FontSize="10" Margin="6,0,0,0"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </HierarchicalDataTemplate>
                                </TreeView.ItemTemplate>
                            </TreeView>
                        </ScrollViewer>
                        <TextBlock Grid.Row="1" Text="扫描后显示目录树" HorizontalAlignment="Center"
                                   VerticalAlignment="Center" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Visibility="{Binding HasScanResult, Converter={StaticResource InvBoolToVis}}"/>
                    </Grid>
                </Border>

                <GridSplitter Grid.Column="1" Width="4" HorizontalAlignment="Stretch" Cursor="SizeWE"
                              Background="{StaticResource BorderBrush}"/>

                <!-- Center Panel: Tab Control -->
                <Border Grid.Column="2" Background="{StaticResource BackgroundDarkBrush}">
                    <TabControl SelectedIndex="{Binding SelectedTabIndex}">

                        <!-- Treemap -->
                        <TabItem Header="🗂 Treemap">
                            <Grid>
                            
                                <ctrl:TreemapControl
    x:Name="TreemapView"
    RootNode="{Binding RootNode}"
    HighlightedNode="{Binding HighlightedNode}"
    SelectedNode="{Binding SelectedNode}"
    HorizontalAlignment="Stretch"
    VerticalAlignment="Stretch"/>
                                
                                
                                
                                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                            Visibility="{Binding HasScanResult, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="💿" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                                    <TextBlock Text="选择驱动器并点击「开始扫描」" FontSize="16"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                    <TextBlock Text="以矩形图可视化磁盘空间占用" FontSize="13" Margin="0,6,0,0"
                                               Foreground="{StaticResource TextSecondaryBrush}"
                                               HorizontalAlignment="Center"/>
                                </StackPanel>
                                <!-- Legend overlay -->
                                <Border HorizontalAlignment="Right" VerticalAlignment="Bottom" Margin="12"
                                        Background="#BB1E1E2E" CornerRadius="8" Padding="10,8"
                                        Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVis}}">
                                    
                                </Border>
                            </Grid>
                        </TabItem>

                        <!-- File List -->
                        <TabItem Header="📋 文件列表">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="32"/>
                                    <RowDefinition Height="*"/>
                                </Grid.RowDefinitions>
                                <Border Background="{StaticResource BackgroundLightBrush}" Padding="12,0">
                                    <TextBlock VerticalAlignment="Center" FontSize="12"
                                               Foreground="{StaticResource TextSecondaryBrush}">
                                        <Run Text="共 "/>
                                        <Run Text="{Binding FileListItems.Count, Mode=OneWay}" FontWeight="SemiBold"
                                             Foreground="{StaticResource TextPrimaryBrush}"/>
                                        <Run Text=" 项（最多500，按大小降序）"/>
                                    </TextBlock>
                                </Border>
                                <ListView Grid.Row="1" ItemsSource="{Binding FileListItems}"
                                          SelectedItem="{Binding SelectedNode}"
                                          SelectionChanged="FileList_SelectionChanged">
                                    <ListView.ContextMenu>
                                        <ContextMenu DataContext="{Binding PlacementTarget.DataContext, RelativeSource={RelativeSource Self}}">
                                            <MenuItem Header="🗑 删除到回收站" Command="{Binding DeleteToRecycleBinCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <MenuItem Header="💀 永久删除" Command="{Binding DeletePermanentlyCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <MenuItem Header="🧹 清空文件夹" Command="{Binding ClearDirectoryCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <Separator/>
                                            <MenuItem Header="📋 复制路径" Command="{Binding CopyPathCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <MenuItem Header="📂 在资源管理器中显示" Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <MenuItem Header="💻 在CMD中打开" Command="{Binding OpenInCmdCommand}" CommandParameter="{Binding SelectedNode}"/>
                                            <Separator/>
                                            <MenuItem Header="🔑 计算哈希 (MD5/SHA1/256/512)" Command="{Binding ComputeHashCommand}" CommandParameter="{Binding SelectedNode}"/>
                                        </ContextMenu>
                                    </ListView.ContextMenu>
                                    <ListView.View>
                                        <GridView>
                                          
                                            
                                            
                                            <GridViewColumn Width="40">
    <GridViewColumn.CellTemplate>
        <DataTemplate>
                 <TextBlock Text="{Binding Converter={StaticResource FileTypeToIconConverter}}"                       
                       FontSize="18"
                       FontFamily="Segoe UI Emoji"
                       HorizontalAlignment="Center"
                       VerticalAlignment="Center"
                       TextAlignment="Center"
                       Width="32"
                       LineHeight="24"
                       LineStackingStrategy="BlockLineHeight"/>
        </DataTemplate>
    </GridViewColumn.CellTemplate>
</GridViewColumn>
                                            
                                            
                                            <GridViewColumn Header="名称" Width="200">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding Name}" FontSize="12" TextTrimming="CharacterEllipsis"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="大小" Width="90">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding SizeText}" FontSize="12" TextAlignment="Right"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="类型" Width="65">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding TypeText}" FontSize="12"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="修改时间" Width="135">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding ModifiedTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                                   FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                            <GridViewColumn Header="完整路径" Width="350">
                                                <GridViewColumn.CellTemplate>
                                                    <DataTemplate>
                                                        <TextBlock Text="{Binding FullPath}" FontSize="12"
                                                                   TextTrimming="CharacterEllipsis"
                                                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                                                    </DataTemplate>
                                                </GridViewColumn.CellTemplate>
                                            </GridViewColumn>
                                        </GridView>
                                    </ListView.View>
                                </ListView>
                            </Grid>
                        </TabItem>

                        <!-- File Type Stats -->
                        <TabItem Header="📊 类型统计">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="1"/>
                                    <ColumnDefinition Width="300"/>
                                </Grid.ColumnDefinitions>
                                <!-- Canvas for pie chart (drawn in code-behind) -->
                                <Canvas x:Name="StatsChartCanvas" Grid.Column="0"
                                        Background="Transparent" Margin="16"
                                        SizeChanged="StatsCanvas_SizeChanged"/>
                                <Border Grid.Column="1" Background="{StaticResource BorderBrush}"/>
                                <Border Grid.Column="2" Background="{StaticResource BackgroundMediumBrush}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="36"/>
                                            <RowDefinition Height="*"/>
                                        </Grid.RowDefinitions>
                                        <Border Background="{StaticResource BackgroundLightBrush}" Padding="12,0">
                                            <TextBlock Text="文件类型分布" VerticalAlignment="Center"
                                                       FontSize="13" FontWeight="SemiBold"/>
                                        </Border>
                                        <ListView Grid.Row="1" ItemsSource="{Binding FileTypeStats}">
                                            <ListView.View>
                                                <GridView>
                                                    <GridViewColumn Header="类型" Width="80">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Border Width="9" Height="9" CornerRadius="2"
                                                                            VerticalAlignment="Center" Margin="0,0,5,0"
                                                                            Background="{Binding Color, Converter={StaticResource ColorToBrush}}"/>
                                                                    <TextBlock Text="{Binding TypeName}" FontSize="12"/>
                                                                </StackPanel>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Header="占用" Width="78">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding SizeText}" FontSize="12"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Header="占比" Width="58">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Percentage, StringFormat={}{0:F1}%}" FontSize="12"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                    <GridViewColumn Header="数量" Width="60">
                                                        <GridViewColumn.CellTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding Count, StringFormat={}{0:N0}}" FontSize="12"/>
                                                            </DataTemplate>
                                                        </GridViewColumn.CellTemplate>
                                                    </GridViewColumn>
                                                </GridView>
                                            </ListView.View>
                                        </ListView>
                                    </Grid>
                                </Border>
                            </Grid>
                        </TabItem>
                    </TabControl>
                </Border>

                <GridSplitter Grid.Column="3" Width="4" HorizontalAlignment="Stretch" Cursor="SizeWE"
                              Background="{StaticResource BorderBrush}"/>

                <!-- Right Panel: File Details -->
                <Border Grid.Column="4" Background="{StaticResource BackgroundMediumBrush}"
                        BorderBrush="{StaticResource BorderBrush}" BorderThickness="1,0,0,0">
                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                        <StackPanel Margin="12">
                            <TextBlock Text="📋 文件详情" FontSize="13" FontWeight="SemiBold" Margin="0,4,0,12"/>

                            <!-- Empty -->
                            <StackPanel HorizontalAlignment="Center" Margin="0,40"
                                        Visibility="{Binding SelectedNode, Converter={StaticResource NullToVis}, ConverterParameter=invert}">
                                <TextBlock Text="🖱" FontSize="32" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                <TextBlock Text="点击文件查看详情" FontSize="12"
                                           Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center"/>
                            </StackPanel>

                            <!-- Details -->
                            <StackPanel Visibility="{Binding SelectedNode, Converter={StaticResource NullToVis}}">
                                <!-- Header Card -->
                                <Border Background="{StaticResource BackgroundLightBrush}"
                                        CornerRadius="8" Padding="12" Margin="0,0,0,12">
                                    <StackPanel HorizontalAlignment="Center">
                                        <TextBlock Text="{Binding SelectedNode, Converter={StaticResource FileTypeIcon}}"
                                                   FontSize="40" HorizontalAlignment="Center" Margin="0,0,0,8"/>
                                        <TextBlock Text="{Binding SelectedNode.Name}" FontWeight="SemiBold"
                                                   FontSize="13" TextWrapping="Wrap" TextAlignment="Center" MaxWidth="240"/>
                                        <TextBlock Text="{Binding SelectedNode.SizeText}" FontSize="18"
                                                   FontWeight="Bold" HorizontalAlignment="Center" Margin="0,6,0,0"
                                                   Foreground="{StaticResource AccentBrush}"/>
                                    </StackPanel>
                                </Border>

                                <!-- Properties -->
                                <StackPanel Margin="0,0,0,12">
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="路径" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedNode.FullPath}"
                                                   FontSize="11" TextWrapping="Wrap"/>
                                    </Grid>
                                    <Separator/>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="类型" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedNode.TypeText}" FontSize="11"/>
                                    </Grid>
                                    <Separator/>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="大小" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding SelectedNode.SizeText}" FontSize="11"/>
                                    </Grid>
                                    <Separator/>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="创建时间" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedNode.CreatedTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                   FontSize="11"/>
                                    </Grid>
                                    <Separator/>
                                    <Grid Margin="0,4">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="72"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="修改时间" FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding SelectedNode.ModifiedTime, StringFormat={}{0:yyyy-MM-dd HH:mm}}"
                                                   FontSize="11"/>
                                    </Grid>
                                </StackPanel>

                                <!-- Quick Actions -->
                                <TextBlock Text="快速操作" FontSize="11" FontWeight="SemiBold" 

                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,8"/>
                                <UniformGrid Columns="2" Margin="0,0,0,6">
                                    <Button Content="📂 打开位置" Margin="0,0,3,3" Height="36" FontSize="11"  

                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding OpenInExplorerCommand}" CommandParameter="{Binding SelectedNode}"/>
                                    <Button Content="📋 复制路径" Margin="3,0,0,3" Height="36" FontSize="11"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding CopyPathCommand}" CommandParameter="{Binding SelectedNode}"/>
                                    <Button Content="💻 CMD" Margin="0,0,3,0" Height="36" FontSize="11"
                                            Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding OpenInCmdCommand}" CommandParameter="{Binding SelectedNode}"/>
                                    <Button Content="🗑 回收站" Margin="3,0,0,0" Height="36" FontSize="11"
                                            Style="{StaticResource DangerButtonStyle}"
                                            Command="{Binding DeleteToRecycleBinCommand}" CommandParameter="{Binding SelectedNode}"/>
                                </UniformGrid>
                                <Button Content="💀 永久删除" HorizontalAlignment="Stretch" Height="36" FontSize="11"
                                        Margin="0,4,0,4" Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding DeletePermanentlyCommand}" CommandParameter="{Binding SelectedNode}"/>
                                <Button Content="🧹 清空文件夹内容" HorizontalAlignment="Stretch" Height="36" FontSize="11"
                                        Margin="0,0,0,12" Style="{StaticResource DangerButtonStyle}"
                                        Command="{Binding ClearDirectoryCommand}" CommandParameter="{Binding SelectedNode}"
                                        Visibility="{Binding SelectedNode.IsDirectory, Converter={StaticResource BoolToVis}}"/>

                                <!-- Hash Section (files only) -->
                                <StackPanel Visibility="{Binding SelectedNode.IsDirectory, Converter={StaticResource InvBoolToVis}}">
                                    <TextBlock Text="文件哈希" FontSize="11" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,4,0,8"/>
                                    <Button Content="🔑 计算 MD5/SHA1/SHA256/SHA512" Height="36" FontSize="11"
                                            HorizontalAlignment="Stretch" Style="{StaticResource SecondaryButtonStyle}"
                                            Command="{Binding ComputeHashCommand}" CommandParameter="{Binding SelectedNode}"
                                            IsEnabled="{Binding IsComputingHash, Converter={StaticResource BoolNeg}}"
                                            Margin="0,0,0,8"/>
                                    <StackPanel Visibility="{Binding HashResult, Converter={StaticResource NullToVis}}">
                                        <Border Background="{StaticResource BackgroundLightBrush}" CornerRadius="6" Padding="10">
                                            <StackPanel>
                                                <TextBlock Text="MD5" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding HashResult.MD5}" FontSize="10"
                                                           FontFamily="Consolas" TextWrapping="Wrap"
                                                           Foreground="{StaticResource AccentBrush}" Margin="0,0,0,6"/>
                                                <TextBlock Text="SHA1" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding HashResult.SHA1}" FontSize="10"
                                                           FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <TextBlock Text="SHA256" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding HashResult.SHA256}" FontSize="10"
                                                           FontFamily="Consolas" TextWrapping="Wrap" Margin="0,0,0,6"/>
                                                <TextBlock Text="SHA512" FontSize="10" FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,2"/>
                                                <TextBlock Text="{Binding HashResult.SHA512}" FontSize="10"
                                                           FontFamily="Consolas" TextWrapping="Wrap"/>
                                            </StackPanel>
                                        </Border>
                                    </StackPanel>
                                </StackPanel>
                            </StackPanel>
                        </StackPanel>
                    </ScrollViewer>
                </Border>
            </Grid>

            <!-- Status Bar -->
            <Border Grid.Row="3" Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center"
                               FontSize="11" Foreground="{StaticResource TextSecondaryBrush}"/>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Fill" Value="#FF9800"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="就绪"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Text" Value="扫描中..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
