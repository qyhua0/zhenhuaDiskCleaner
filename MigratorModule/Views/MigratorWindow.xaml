<Window x:Class="ZhenhuaDiskCleaner.MigratorModule.Views.MigratorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ZhenhuaDiskCleaner.MigratorModule.ViewModels"
        xmlns:m="clr-namespace:ZhenhuaDiskCleaner.MigratorModule.Models"
        xmlns:conv="clr-namespace:ZhenhuaDiskCleaner.Converters"
        Title="个人资料迁移"
        Height="640" Width="700"
        MinHeight="500" MinWidth="580"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}">

    <Window.Resources>
        <conv:BoolToVisibilityConverter        x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:BoolToNegateConverter            x:Key="BoolNeg"/>

        <!-- WarningButtonStyle 本地声明（与 MainWindow 一致，避免资源查找跨窗口） -->
        <Style x:Key="WarningButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
        </Style>

        <!-- 文件夹行卡片 -->
        <Style x:Key="CardBorderStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BackgroundMediumBrush}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="5"/>
            <Setter Property="Margin"          Value="0,0,0,5"/>
            <Setter Property="Padding"         Value="12,8"/>
        </Style>

        <!-- 已迁移绿色徽章 -->
        <Style x:Key="MigratedBadgeStyle" TargetType="Border">
            <Setter Property="Background"      Value="#1A4CAF50"/>
            <Setter Property="BorderBrush"     Value="#4CAF50"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="3"/>
            <Setter Property="Padding"         Value="6,1"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
        </Style>

        <!-- 路径有效 ✓ 绿色 -->
        <Style x:Key="ValidIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="#4CAF50"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="6,0,0,0"/>
        </Style>

        <!-- 路径无效 ✗ 红色 -->
        <Style x:Key="InvalidIconStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="#F44336"/>
            <Setter Property="FontSize"         Value="14"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Margin"           Value="6,0,0,0"/>
        </Style>
    </Window.Resources>

    <!-- 窗口圆角外框 -->
    <Border CornerRadius="8"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40"/>
                <!-- 0: 标题栏 -->
                <RowDefinition Height="Auto"/>
                <!-- 1: 目标盘工具栏 -->
                <RowDefinition Height="*"/>
                <!-- 2: 文件夹列表 -->
                <RowDefinition Height="Auto"/>
                <!-- 3: 进度条（迁移中显示）-->
                <RowDefinition Height="Auto"/>
                <!-- 4: 注意事项 -->
                <RowDefinition Height="50"/>
                <!-- 5: 操作栏 -->
                <RowDefinition Height="24"/>
                <!-- 6: 状态栏 -->
            </Grid.RowDefinitions>

            <!-- ════════════════════════════════════════════════════════
                 Row 0 — 标题栏
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Margin="14,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="📁" FontSize="15" Margin="0,0,7,0"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="系统盘个人资料迁移"
                                   FontSize="13" FontWeight="SemiBold"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <!-- 最小化 / 关闭 -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="─" Width="34" Height="26"
                                Background="Transparent" BorderThickness="0"
                                FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                Click="Minimize_Click"/>
                        <Button Content="✕" Width="34" Height="26"
                                Background="Transparent" BorderThickness="0"
                                FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                Click="Close_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Row 1 — 目标盘工具栏
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="14,8">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 标签 -->
                        <ColumnDefinition Width="80"/>
                        <!-- 驱动器下拉 -->
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 可用空间 -->
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 全选按钮 -->
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>
                        <!-- 刷新按钮 -->
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Column="0" Text="目标磁盘："
                               VerticalAlignment="Center" FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <ComboBox Grid.Column="1" x:Name="DriveCombo"
                              ItemsSource="{Binding AvailableDrives}"
                              Height="28" FontSize="12"
                              IsEnabled="{Binding IsMigrating, Converter={StaticResource BoolNeg}}"
                              SelectionChanged="DriveCombo_SelectionChanged">
                        <ComboBox.ItemTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="12"/>
                            </DataTemplate>
                        </ComboBox.ItemTemplate>
                    </ComboBox>

                    <TextBlock Grid.Column="3"
                               Text="{Binding DriveFreeText}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"/>

                    <Button Grid.Column="5" Content="全选 / 取消"
                            Height="28" Padding="10,0" FontSize="12"
                            Style="{StaticResource SecondaryButtonStyle}"
                            IsEnabled="{Binding IsMigrating, Converter={StaticResource BoolNeg}}"
                            Command="{Binding ToggleSelectAllCommand}"/>

                    <Button Grid.Column="7" Content="刷新"
                            Height="28" Padding="10,0" FontSize="12"
                            Style="{StaticResource SecondaryButtonStyle}"
                            ToolTip="重新扫描文件夹"
                            IsEnabled="{Binding IsMigrating, Converter={StaticResource BoolNeg}}"
                            Command="{Binding RefreshCommand}"/>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Row 2 — 文件夹列表（与需求文档线框完全对应）
            ════════════════════════════════════════════════════════ -->
            <ScrollViewer Grid.Row="2"
                          VerticalScrollBarVisibility="Auto"
                          Padding="12,8,12,4">
                <Grid>
                    <!-- 扫描中占位 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Margin="0,40,0,0"
                                Visibility="{Binding IsScanning,
                                             Converter={StaticResource BoolToVis}}">
                        <TextBlock Text="🔍" FontSize="32"
                                   HorizontalAlignment="Center" Margin="0,0,0,8"/>
                        <TextBlock Text="正在扫描…" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>

                    <!-- 文件夹卡片列表 -->
                    <ItemsControl ItemsSource="{Binding Folders}"
                                  Visibility="{Binding IsScanning,
                                               Converter={StaticResource InvBoolToVis}}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type m:FolderItem}">
                                <Border Style="{StaticResource CardBorderStyle}">
                                    <Grid MinHeight="52">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="22"/>
                                            <!-- 复选框 -->
                                            <ColumnDefinition Width="28"/>
                                            <!-- 图标 -->
                                            <ColumnDefinition Width="48"/>
                                            <!-- 名称 -->
                                            <ColumnDefinition Width="8"/>
                                            <ColumnDefinition Width="*"/>
                                            <!-- 路径区（两行）-->
                                            <ColumnDefinition Width="Auto"/>
                                            <!-- 右侧状态 -->
                                        </Grid.ColumnDefinitions>

                                        <!-- 复选框 -->
                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsChecked, Mode=TwoWay}"
                                                  IsEnabled="{Binding AlreadyMigrated,
                                                              Converter={StaticResource BoolNeg}}"
                                                  VerticalAlignment="Center"/>

                                        <!-- 图标 -->
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Icon}" FontSize="18"
                                                   VerticalAlignment="Center"
                                                   HorizontalAlignment="Center"/>

                                        <!-- 名称 -->
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding DisplayName}"
                                                   FontSize="12" FontWeight="SemiBold"
                                                   VerticalAlignment="Center"/>

                                        <!-- 路径区：上行=源路径，下行=目标路径编辑框 -->
                                        <StackPanel Grid.Column="4" VerticalAlignment="Center"
                                                    Margin="0,2,0,2">
                                            <!-- 源路径（可点击打开资源管理器） -->
                                            <TextBlock Text="{Binding SourcePath}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource AccentBrush}"
                                                       TextTrimming="CharacterEllipsis"
                                                       ToolTip="点击打开文件夹"
                                                       Margin="0,0,0,4"
                                                       Cursor="Hand"
                                                       Tag="{Binding SourcePath}"
                                                       MouseLeftButtonUp="SourcePath_Click">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Style.Triggers>
                                                            <Trigger Property="IsMouseOver" Value="True">
                                                                <Setter Property="TextDecorations" Value="Underline"/>
                                                            </Trigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <!-- 目标路径行：编辑框 + 浏览按钮 + 大小 -->
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="30"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBox Grid.Column="0"
                                                         Text="{Binding TargetPath,
                                                                UpdateSourceTrigger=LostFocus}"
                                                         FontSize="11"
                                                         IsEnabled="{Binding AlreadyMigrated,
                                                                     Converter={StaticResource BoolNeg}}"
                                                         ToolTip="{Binding TargetPath}"
                                                         LostFocus="TargetPath_LostFocus">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Background"      Value="{StaticResource BackgroundLightBrush}"/>
                                                            <Setter Property="Foreground"      Value="{StaticResource TextPrimaryBrush}"/>
                                                            <Setter Property="BorderBrush"     Value="{StaticResource BorderBrush}"/>
                                                            <Setter Property="BorderThickness" Value="1"/>
                                                            <Setter Property="Padding"         Value="6,0"/>
                                                            <Setter Property="Height"          Value="24"/>
                                                            <Setter Property="VerticalContentAlignment" Value="Center"/>
                                                            <Setter Property="Template">
                                                                <Setter.Value>
                                                                    <ControlTemplate TargetType="TextBox">
                                                                        <Border Background="{TemplateBinding Background}"
                                                                                BorderBrush="{TemplateBinding BorderBrush}"
                                                                                BorderThickness="{TemplateBinding BorderThickness}"
                                                                                CornerRadius="4">
                                                                            <ScrollViewer x:Name="PART_ContentHost"
                                                                                          Margin="{TemplateBinding Padding}"
                                                                                          VerticalAlignment="Center"/>
                                                                        </Border>
                                                                    </ControlTemplate>
                                                                </Setter.Value>
                                                            </Setter>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <Button Grid.Column="1"
                                                        Content="📂" Height="24" Width="26"
                                                        FontSize="11" Margin="3,0,0,0"
                                                        Style="{StaticResource SecondaryButtonStyle}"
                                                        ToolTip="选择目标文件夹"
                                                        IsEnabled="{Binding AlreadyMigrated,
                                                                    Converter={StaticResource BoolNeg}}"
                                                        Command="{Binding DataContext.BrowseCommand,
                                                                  RelativeSource={RelativeSource
                                                                  AncestorType=ItemsControl}}"
                                                        CommandParameter="{Binding}"/>
                                                <!-- 大小文字 -->
                                                <TextBlock Grid.Column="2"
                                                           Margin="8,0,0,0"
                                                           FontSize="11" VerticalAlignment="Center"
                                                           Foreground="{StaticResource TextSecondaryBrush}">
                                                    <Run Text="{Binding SizeText}"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         FontWeight="SemiBold"/>
                                                </TextBlock>
                                            </Grid>
                                            <!-- 路径无效提示 -->
                                            <TextBlock Text="{Binding PathValidMsg}"
                                                       FontSize="10" Foreground="#F44336"
                                                       Margin="0,3,0,0"
                                                       Visibility="{Binding PathValid,
                                                                    Converter={StaticResource InvBoolToVis}}"/>
                                        </StackPanel>

                                        <!-- 右侧：✓ / ✗ / 已迁移徽章 -->
                                        <StackPanel Grid.Column="5"
                                                    VerticalAlignment="Center"
                                                    Margin="8,0,0,0">
                                            <!-- 路径有效 ✓ -->
                                            <TextBlock Text="✓" FontSize="16"
                                                       Foreground="#4CAF50"
                                                       ToolTip="目标路径有效"
                                                       Visibility="{Binding PathValid,
                                                                    Converter={StaticResource BoolToVis}}"/>
                                            <!-- 路径无效 ✗ -->
                                            <TextBlock Text="✗" FontSize="16"
                                                       Foreground="#F44336"
                                                       ToolTip="{Binding PathValidMsg}"
                                                       Visibility="{Binding PathValid,
                                                                    Converter={StaticResource InvBoolToVis}}"/>
                                            <!-- 已迁移徽章 -->
                                            <Border Style="{StaticResource MigratedBadgeStyle}"
                                                    Visibility="{Binding AlreadyMigrated,
                                                                 Converter={StaticResource BoolToVis}}">
                                                <TextBlock Text="✔ 已迁移" FontSize="10"
                                                           Foreground="#4CAF50"/>
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </ScrollViewer>

            <!-- ════════════════════════════════════════════════════════
                 Row 3 — 迁移进度（始终显示）
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Padding="14,10"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid>
                    <!-- 未迁移时：就绪提示 -->
                    <TextBlock Text="勾选文件夹后点击「迁移」开始"
                               FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Visibility="{Binding IsMigrating,
                                            Converter={StaticResource InvBoolToVis}}"/>

                    <!-- 迁移中：详细进度 -->
                    <StackPanel Visibility="{Binding IsMigrating,
                                             Converter={StaticResource BoolToVis}}">

                        <!-- 顶行：当前文件夹名 + 总百分比 -->
                        <Grid Margin="0,0,0,6">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <!-- 跳动指示点 -->
                                <Ellipse Width="7" Height="7" Margin="0,0,7,0"
                                         VerticalAlignment="Center">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Setter Property="Fill" Value="{StaticResource AccentBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsMigrating}" Value="True">
                                                    <DataTrigger.EnterActions>
                                                        <BeginStoryboard>
                                                            <Storyboard RepeatBehavior="Forever">
                                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                                 From="1" To="0.2" Duration="0:0:0.8"
                                                                                 AutoReverse="True"/>
                                                            </Storyboard>
                                                        </BeginStoryboard>
                                                    </DataTrigger.EnterActions>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock FontSize="11"
                                           Foreground="{StaticResource TextSecondaryBrush}">
                                    <Run Text="正在迁移："/>
                                    <Run Text="{Binding CurrentFolder}"
                                         Foreground="{StaticResource TextPrimaryBrush}"
                                         FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                            <!-- 右侧：百分比 -->
                            <TextBlock HorizontalAlignment="Right" FontSize="12"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}"
                                       Text="{Binding OverallProgress,
                                              StringFormat={}{0}%}"/>
                        </Grid>

                        <!-- 总进度条 -->
                        <ProgressBar Style="{StaticResource ScanProgressBarStyle}"
                                     Value="{Binding OverallProgress}"
                                     Maximum="100" Height="8"
                                     Margin="0,0,0,5"/>

                        <!-- 当前文件夹进度行 -->
                        <Grid>
                            <TextBlock FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="当前文件夹"/>
                            <TextBlock HorizontalAlignment="Right" FontSize="10"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Text="{Binding FolderProgress,
                                              StringFormat={}{0}%}"/>
                        </Grid>
                        <ProgressBar Style="{StaticResource ScanProgressBarStyle}"
                                     Value="{Binding FolderProgress}"
                                     Maximum="100" Height="4"
                                     Opacity="0.5"
                                     Margin="0,3,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Row 4 — 注意事项（与需求文档原文一致）
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Background="#08FFC107"
                    BorderBrush="#22FFC107"
                    BorderThickness="0,1,0,0"
                    Padding="14,9">
                <StackPanel>
                    <TextBlock Text="注意："
                               FontSize="11" FontWeight="SemiBold"
                               Foreground="#FFC107" Margin="0,0,0,4"/>
                    <TextBlock FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextWrapping="Wrap" LineHeight="20">
                        <Run Text="1. C:\Users\{用户名} 当前用户目录在 C 盘变更后的目标盘"/>
                        <LineBreak/>
                        <Run Text="2. 已变更用户目录会导致部分软件数据也跟随迁移"/>
                        <LineBreak/>
                        <Run Text="3. 迁移前请确保先保存当前工作文件并备份重要数据"/>
                        <LineBreak/>
                        <Run Text="4. 迁移过程需要重启计算机完成最终配置"/>
                    </TextBlock>
                </StackPanel>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Row 5 — 底部操作栏
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="5"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="14,0">
                <Grid>
                    <!-- 左：日志按钮 -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="📋 导出日志"
                                Height="30" Padding="12,0" FontSize="12"
                                Style="{StaticResource SecondaryButtonStyle}"
                                Command="{Binding ExportLogCommand}"/>
                    </StackPanel>

                    <!-- 右：取消 / 迁移 -->
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="⏹ 取消迁移"
                                Height="30" Padding="12,0" Margin="0,0,8,0" FontSize="12"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding CancelMigrationCommand}"
                                Visibility="{Binding IsMigrating,
                                             Converter={StaticResource BoolToVis}}"/>

                        <Button Height="30" Padding="20,0" FontSize="12"
                                Style="{StaticResource WarningButtonStyle}"
                                Command="{Binding MigrateCommand}"
                                IsEnabled="{Binding CanMigrate}"
                                Visibility="{Binding IsMigrating,
                                             Converter={StaticResource InvBoolToVis}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="📁" Margin="0,0,5,0"/>
                                <TextBlock Text="迁移"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ════════════════════════════════════════════════════════
                 Row 6 — 状态栏
            ════════════════════════════════════════════════════════ -->
            <Border Grid.Row="6"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <TextBlock Text="{Binding StatusMessage}"
                           Margin="14,0" VerticalAlignment="Center"
                           FontSize="10"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           TextTrimming="CharacterEllipsis"/>
            </Border>
        </Grid>
    </Border>
</Window>
