<Window x:Class="ZhenhuaDiskCleaner.CleanerModule.Views.CleanerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ZhenhuaDiskCleaner.CleanerModule.ViewModels"
        xmlns:models="clr-namespace:ZhenhuaDiskCleaner.CleanerModule.Models"
        xmlns:conv="clr-namespace:ZhenhuaDiskCleaner.Converters"
        Title="系统盘清理"
        Height="700" Width="860"
        MinHeight="560" MinWidth="700"
        Background="{StaticResource BackgroundDarkBrush}"
        Foreground="{StaticResource TextPrimaryBrush}"
        WindowStyle="None"
        AllowsTransparency="True"
        ResizeMode="CanResizeWithGrip"
        WindowStartupLocation="CenterOwner">

    <Window.Resources>
        <conv:BoolToVisibilityConverter    x:Key="BoolToVis"/>
        <conv:InverseBoolToVisibilityConverter x:Key="InvBoolToVis"/>
        <conv:BoolToNegateConverter        x:Key="BoolNeg"/>

        <!-- WarningButton：橙色，用于清理按钮 -->
        <Style x:Key="WarningButtonStyle" TargetType="Button"
               BasedOn="{StaticResource PrimaryButtonStyle}">
            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
        </Style>

        <!-- 进度条（清理专用，绿色） -->
        <Style x:Key="CleanProgressStyle" TargetType="ProgressBar"
               BasedOn="{StaticResource ScanProgressBarStyle}">
            <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
        </Style>

        <!-- CheckBox 深色主题 -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
    </Window.Resources>

    <!-- 圆角主框 -->
    <Border CornerRadius="10"
            BorderBrush="{StaticResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="42"/>   <!-- 标题栏 -->
                <RowDefinition Height="Auto"/> <!-- 磁盘状态面板 -->
                <RowDefinition Height="Auto"/> <!-- 扫描进度条（扫描中可见） -->
                <RowDefinition Height="*"/>    <!-- 扫描结果列表 -->
                <RowDefinition Height="Auto"/> <!-- 清理进度条（清理中可见） -->
                <RowDefinition Height="60"/>   <!-- 底部工具栏 -->
                <RowDefinition Height="28"/>   <!-- 状态栏 -->
            </Grid.RowDefinitions>

            <!-- ══════════════════════════════════════════════════════════
                 标题栏
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="0"
                    Background="{StaticResource BackgroundMediumBrush}"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="16,0">
                        <TextBlock Text="🧹" FontSize="17" Margin="0,0,8,0"/>
                        <TextBlock Text="系统盘清理" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock Text=" — C:\" FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Bottom" Margin="0,0,0,1"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                Margin="0,0,4,0">
                        <Button Content="─" Width="36" Height="28" Click="Minimize_Click"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"/>
                        <Button Content="□" Width="36" Height="28" Click="Maximize_Click"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"/>
                        <Button Content="✕" Width="36" Height="28" Click="Close_Click"
                                Background="Transparent" BorderThickness="0" FontSize="14"
                                Foreground="{StaticResource TextSecondaryBrush}" Cursor="Hand"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 磁盘状态面板（顶部信息卡）
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="1"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    Padding="16,12">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- 左：容量信息 + 进度条 -->
                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                        <!-- 驱动器标签行 -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,6">
                            <TextBlock Text="💿" FontSize="15" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock FontSize="14" FontWeight="SemiBold" VerticalAlignment="Center">
                                <Run Text="{Binding DiskInfo.DriveName, Mode=OneWay}"/>
                                <Run Text=" "/>
                                <Run Text="{Binding DiskInfo.VolumeLabel, Mode=OneWay}"
                                     Foreground="{StaticResource TextSecondaryBrush}"/>
                            </TextBlock>
                            <Border Background="{StaticResource AccentBrush}"
                                    CornerRadius="3" Padding="6,2" Margin="10,0,0,0"
                                    VerticalAlignment="Center">
                                <TextBlock FontSize="11" Foreground="White">
                                    <Run Text="{Binding DiskInfo.UsedPercent, StringFormat={}{0:F0}%,  Mode=OneWay}"/>
                                    <Run Text="已用"/>
                                </TextBlock>
                            </Border>
                        </StackPanel>

                        <!-- 磁盘使用进度条 -->
                        <ProgressBar Height="8" Margin="0,0,0,6" Maximum="100"
                                     Value="{Binding DiskInfo.UsedPercent, Mode=OneWay}"
                                     Style="{StaticResource ScanProgressBarStyle}"/>

                        <!-- 容量数字行 -->
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                                <Run Text="总容量 "/>
                                <Run Text="{Binding DiskInfo.TotalText, Mode=OneWay}"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                <Run Text="   已用 "/>
                                <Run Text="{Binding DiskInfo.UsedText, Mode=OneWay}"
                                     Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                <Run Text="   可用 "/>
                                <Run Text="{Binding DiskInfo.FreeText, Mode=OneWay}"
                                     Foreground="{StaticResource SuccessBrush}" FontWeight="SemiBold"/>
                            </TextBlock>
                        </StackPanel>
                    </StackPanel>

                    <!-- 右：扫描 + 清理 按钮组 -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal"
                                VerticalAlignment="Center" Margin="16,0,0,0">

                        <!-- 开始扫描 / 取消扫描 -->
                        <Button Width="110" Height="36" Padding="0"
                                Style="{StaticResource PrimaryButtonStyle}"
                                Command="{Binding StartScanCommand}"
                                Visibility="{Binding IsScanning, Converter={StaticResource InvBoolToVis}}">
                            <TextBlock Text="🔍  开始扫描"/>
                        </Button>
                        <Button Width="110" Height="36" Padding="0" Margin="0"
                                Style="{StaticResource DangerButtonStyle}"
                                Command="{Binding CancelScanCommand}"
                                Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="⏹  停止扫描"/>
                        </Button>

                        <Border Width="1" Background="{StaticResource BorderBrush}" Margin="10,6"/>

                        <!-- 一键清理 -->
                        <Button Width="120" Height="36" Padding="0" Margin="0,0,0,0"
                                Style="{StaticResource WarningButtonStyle}"
                                Command="{Binding CleanSelectedCommand}"
                                IsEnabled="{Binding IsCleaning, Converter={StaticResource BoolNeg}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="🧹  一键清理" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 扫描进度条（仅扫描中显示）
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="2"
                    Padding="16,6"
                    Background="{StaticResource BackgroundMediumBrush}"
                    Visibility="{Binding IsScanning, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="正在扫描中..." FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <ProgressBar Style="{StaticResource ScanProgressBarStyle}"
                                 Maximum="100"
                                 Value="{Binding ScanProgress, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 扫描结果 TreeView
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="3"
                    Background="{StaticResource BackgroundDarkBrush}">
                <Grid>
                    <!-- 空状态提示 -->
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center"
                                Visibility="{Binding HasScanResult, Converter={StaticResource InvBoolToVis}}">
                        <TextBlock Text="🧹" FontSize="52" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                        <TextBlock Text="点击「开始扫描」检测 C 盘垃圾文件"
                                   FontSize="15" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"/>
                        <TextBlock Text="扫描完成后在此显示可清理的文件列表"
                                   FontSize="12" HorizontalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,6,0,0"/>
                    </StackPanel>

                    <!-- 结果树 -->
                    <ScrollViewer VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled"
                                  Visibility="{Binding HasScanResult, Converter={StaticResource BoolToVis}}">
                        <TreeView x:Name="ResultTree"
                                  ItemsSource="{Binding Results}"
                                  Background="Transparent"
                                  BorderThickness="0"
                                  Padding="8,4">
                            <TreeView.ItemContainerStyle>
                                <Style TargetType="TreeViewItem">
                                    <Setter Property="IsExpanded" Value="{Binding IsExpanded, Mode=TwoWay}"/>
                                    <Setter Property="Padding"    Value="2,2"/>
                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                                    <!-- 展开折叠箭头 -->
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="TreeViewItem">
                                                <StackPanel>
                                                    <Border x:Name="Bd" CornerRadius="5" Margin="0,1"
                                                            Background="Transparent" Padding="4,3">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="16"/>
                                                                <ColumnDefinition Width="*"/>
                                                            </Grid.ColumnDefinitions>
                                                            <ToggleButton x:Name="Exp"
                                                                IsChecked="{Binding IsExpanded, RelativeSource={RelativeSource TemplatedParent}}"
                                                                ClickMode="Press" Width="16" Height="16"
                                                                Style="{StaticResource {x:Static ToolBar.ToggleButtonStyleKey}}">
                                                                <Path x:Name="Arrow"
                                                                      Data="M 0 0 L 4 4 L 8 0 Z"
                                                                      Fill="{StaticResource TextSecondaryBrush}"
                                                                      HorizontalAlignment="Center"
                                                                      VerticalAlignment="Center"/>
                                                            </ToggleButton>
                                                            <ContentPresenter Grid.Column="1"
                                                                ContentSource="Header"
                                                                VerticalAlignment="Center"/>
                                                        </Grid>
                                                    </Border>
                                                    <ItemsPresenter x:Name="Items" Margin="24,0,0,0"/>
                                                </StackPanel>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsExpanded" Value="False">
                                                        <Setter TargetName="Items"  Property="Visibility" Value="Collapsed"/>
                                                        <Setter TargetName="Arrow"  Property="Data" Value="M 0 0 L 4 4 L 8 0 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="IsExpanded" Value="True">
                                                        <Setter TargetName="Arrow"  Property="Data" Value="M 0 4 L 4 0 L 8 4 Z"/>
                                                    </Trigger>
                                                    <Trigger Property="HasItems" Value="False">
                                                        <Setter TargetName="Exp" Property="Visibility" Value="Hidden"/>
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="Bd" Property="Background"
                                                                Value="{StaticResource BackgroundLightBrush}"/>
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </TreeView.ItemContainerStyle>

                            <TreeView.ItemTemplate>
                                <!-- 一级节点：垃圾分类 -->
                                <HierarchicalDataTemplate DataType="{x:Type models:ScanResult}"
                                                          ItemsSource="{Binding FileEntries}">
                                    <Grid Margin="0,3">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>   <!-- CheckBox -->
                                            <ColumnDefinition Width="Auto"/>   <!-- 图标 -->
                                            <ColumnDefinition Width="*"/>      <!-- 名称 -->
                                            <ColumnDefinition Width="Auto"/>   <!-- 大小 -->
                                            <ColumnDefinition Width="Auto"/>   <!-- 文件数 -->
                                            <ColumnDefinition Width="Auto"/>   <!-- 类型标签 -->
                                        </Grid.ColumnDefinitions>

                                        <CheckBox Grid.Column="0"
                                                  IsChecked="{Binding IsChecked}"
                                                  Margin="0,0,8,0" VerticalAlignment="Center"
                                                  Checked="OnResultCheckedChanged"
                                                  Unchecked="OnResultCheckedChanged"/>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Icon}" FontSize="14"
                                                   Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Grid.Column="2"
                                                   Text="{Binding Name}" FontSize="13"
                                                   FontWeight="SemiBold" VerticalAlignment="Center"
                                                   ToolTip="{Binding Description}"/>
                                        <TextBlock Grid.Column="3"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Margin="12,0,10,0" VerticalAlignment="Center"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   Text="{Binding SizeText}"/>
                                        <TextBlock Grid.Column="4"
                                                   FontSize="11" VerticalAlignment="Center"
                                                   Foreground="{StaticResource TextSecondaryBrush}">
                                            <Run Text="{Binding FileCount, Mode=OneWay}"/><Run Text=" 个文件"/>
                                        </TextBlock>
                                        <!-- 类型标签：推荐/专业 -->
                                        <Border Grid.Column="5" Margin="10,0,0,0"
                                                CornerRadius="3" Padding="5,1"
                                                VerticalAlignment="Center">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#3300A87A"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding RuleType}" Value="professional">
                                                            <Setter Property="Background" Value="#33FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock FontSize="10" VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text"       Value="推荐"/>
                                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding RuleType}" Value="professional">
                                                                <Setter Property="Text"       Value="专业"/>
                                                                <Setter Property="Foreground" Value="{StaticResource WarningBrush}"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </Grid>

                                    <!-- 二级节点：具体文件 -->
                                    <HierarchicalDataTemplate.ItemTemplate>
                                        <DataTemplate DataType="{x:Type models:FileEntry}">
                                            <Grid Margin="0,1">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Grid.Column="0"
                                                           FontSize="11"
                                                           TextTrimming="CharacterEllipsis"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           ToolTip="{Binding FullPath}"
                                                           Text="{Binding FullPath}"/>
                                                <TextBlock Grid.Column="1"
                                                           FontSize="11" Margin="12,0,0,0"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Text="{Binding SizeText}"/>
                                                <!-- 右键菜单 -->
                                                <Grid.ContextMenu>
                                                    <ContextMenu>
                                                        <MenuItem Header="📂  打开文件所在目录"
                                                                  CommandParameter="{Binding}"
                                                                  Click="OpenInExplorer_Click"/>
                                                        <MenuItem Header="📋  复制文件路径"
                                                                  CommandParameter="{Binding}"
                                                                  Click="CopyFilePath_Click"/>
                                                    </ContextMenu>
                                                </Grid.ContextMenu>
                                            </Grid>
                                        </DataTemplate>
                                    </HierarchicalDataTemplate.ItemTemplate>
                                </HierarchicalDataTemplate>
                            </TreeView.ItemTemplate>
                        </TreeView>
                    </ScrollViewer>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 清理进度条（仅清理中显示）
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="4"
                    Padding="16,6"
                    Background="{StaticResource BackgroundMediumBrush}"
                    Visibility="{Binding IsCleaning, Converter={StaticResource BoolToVis}}">
                <StackPanel>
                    <TextBlock Text="正在清理文件..." FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,0,0,4"/>
                    <ProgressBar Style="{StaticResource CleanProgressStyle}"
                                 Maximum="100"
                                 Value="{Binding CleanProgress, Mode=OneWay}"/>
                </StackPanel>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 底部工具栏（全选 / 推荐 / 专业 / 可清理空间）
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="5"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0"
                    Padding="16,0">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>  <!-- 全选 -->
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>  <!-- 推荐 -->
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>  <!-- 专业 -->
                        <ColumnDefinition Width="8"/>
                        <ColumnDefinition Width="Auto"/>  <!-- 取消 -->
                        <ColumnDefinition Width="*"/>     <!-- 弹性 -->
                        <ColumnDefinition Width="Auto"/>  <!-- 可清理大小 -->
                    </Grid.ColumnDefinitions>

                    <Button Grid.Column="0" Content="全选"
                            Height="30" Padding="14,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SelectAllCommand}"/>
                    <Button Grid.Column="2" Content="✔ 推荐"
                            Height="30" Padding="14,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SelectRecommendCommand}"/>
                    <Button Grid.Column="4" Content="⚙ 专业"
                            Height="30" Padding="14,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SelectProfessionalCommand}"/>
                    <Button Grid.Column="6" Content="取消全选"
                            Height="30" Padding="14,0"
                            Style="{StaticResource SecondaryButtonStyle}"
                            Command="{Binding SelectNoneCommand}"/>

                    <!-- 可清理空间 + 上次释放 -->
                    <StackPanel Grid.Column="8" Orientation="Horizontal"
                                VerticalAlignment="Center">
                        <!-- 上次清理释放（清理后显示） -->
                        <StackPanel Orientation="Horizontal" Margin="0,0,20,0"
                                    Visibility="{Binding HasLastFreed, Converter={StaticResource BoolToVis}}">
                            <TextBlock Text="✔ 上次释放 " FontSize="12"
                                       Foreground="{StaticResource SuccessBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding LastFreedText}" FontSize="13"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource SuccessBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <!-- 当前已勾选大小 -->
                        <TextBlock FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center">
                            <Run Text="已选 "/>
                            <Run Text="{Binding SelectedSizeText, Mode=OneWay}"
                                 Foreground="{StaticResource WarningBrush}"
                                 FontWeight="SemiBold" FontSize="14"/>
                            <Run Text=" 可释放"/>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══════════════════════════════════════════════════════════
                 状态栏
            ═══════════════════════════════════════════════════════════ -->
            <Border Grid.Row="6"
                    Background="{StaticResource BackgroundMediumBrush}"
                    BorderBrush="{StaticResource BorderBrush}"
                    BorderThickness="0,1,0,0">
                <Grid Margin="12,0">
                    <TextBlock Text="{Binding StatusMessage}"
                               VerticalAlignment="Center" FontSize="11"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               TextTrimming="CharacterEllipsis"/>
                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center">
                        <Ellipse Width="6" Height="6" Margin="0,0,6,0">
                            <Ellipse.Style>
                                <Style TargetType="Ellipse">
                                    <Setter Property="Fill" Value="#4CAF50"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Fill" Value="#FF9800"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCleaning}" Value="True">
                                            <Setter Property="Fill" Value="#2196F3"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Ellipse.Style>
                        </Ellipse>
                        <TextBlock VerticalAlignment="Center" FontSize="11"
                                   Foreground="{StaticResource TextSecondaryBrush}">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="就绪"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsScanning}" Value="True">
                                            <Setter Property="Text" Value="扫描中..."/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsCleaning}" Value="True">
                                            <Setter Property="Text" Value="清理中..."/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
    </Border>
</Window>
